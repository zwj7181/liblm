{
  "name": "root",
  "private": true,
  "scripts": {
    "start:basic": "pnpm workspace @lm_fe/basic-example start",
    "start:m": "pnpm workspace @lm_fe/basic-example-m start",
    "build": "lerna run build",
    "build1": "lerna exec -- rollup -c=../../rollup.config.js",
    "watch": "lerna exec --no-sort -- rollup -w -c=../../rollup.config.js",
    "clean": "lerna run clean",
    "lerna:clean": "lerna clean",
    "lint": "lerna run lint",
    "test": "lerna run test",
    "check-packages": "pnpm clean && pnpm test && pnpm lint && pnpm build",
    "precommit": "lint-staged",
    "boot": "lerna bootstrap",
    "lerna:publish": "lerna publish patch --registry=https://registry.npmjs.org/ -y",
    "release": "pnpm build && pnpm lerna:publish",
    "release:local": "./compress_packages.sh",
    "commit:release": "git add . && git commit -m 'publish'",
    "helper:serve": "pm2 start ./helper/target/release/lmfe_server",
    "helper": "./helper/target/debug/lm_fe_server",
    "preboot": "cd packages/scripts && pnpm build",
    "link:static2": "rimraf ./node_modules/@lm_fe/static -rf && ln -s ../../../static/packages/static ./node_modules/@lm_fe/static",
    "link:static": "p link file:../static/packages/static/"
  },
  "publishConfig": {
    "access": "public"
  },
